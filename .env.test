# Test-environment defaults - loaded automatically when NODE_ENV=test (Vitest)
# via @next/env's loadEnvConfig in vitest.setup.ts. Committed on purpose: these
# are throwaway, non-sensitive values, NOT real credentials.
#
# Only put broadly-needed, non-secret infra defaults here. Env that a specific
# test exercises (e.g. a missing/invalid API_BASE_URL -> "misconfigured" path) is
# set per-test with vi.stubEnv(...) so those cases stay testable.

# Required by lib/auth/session.ts (sealSession/readSession) across many tests.
# Any >=32-char string works; it only needs to be consistent within the run.
SESSION_SECRET=test-session-secret-at-least-32-chars-long
