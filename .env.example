# OAuth client credentials for the 101Digital identity server (server-only - no NEXT_PUBLIC_ prefix).
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret
# Identity server base URL (no trailing slash).
AUTH_BASE_URL=https://example.com
# Base URL for the 101Digital neobank API gateway (server-only - no NEXT_PUBLIC_ prefix).
API_BASE_URL=https://example.com
# Secret used to encrypt the session cookie (server-only, >= 32 chars).
# Generate with: openssl rand -base64 32
SESSION_SECRET=replace-with-a-32-char-min-random-string
